FROM node:22.12.0-alpine AS build

WORKDIR /app/flower-shop-web

COPY flower-shop-web/package*.json ./
RUN npm ci

WORKDIR /app
COPY shared ./shared
COPY flower-shop-web ./flower-shop-web

WORKDIR /app/flower-shop-web
ARG VITE_API_BASE_URL=""
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
RUN npm run build

FROM nginx:1.27-alpine

COPY flower-shop-web/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/flower-shop-web/dist /usr/share/nginx/html

EXPOSE 80
