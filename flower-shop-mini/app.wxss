page {
  background: #f7fbf7;
  color: #333333;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.page-head {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.page-eyebrow {
  color: #2e7d32;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.5;
}

.page-title-text {
  color: #1f2937;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.4;
}

.page-desc-text {
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.7;
}

.section-title {
  margin: 36rpx 0 20rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.section-subtitle {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.7;
}

.primary-button {
  border-radius: 999rpx;
  background: #2e7d32;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 84rpx;
}

.primary-button::after {
  border: 0;
}

.secondary-button {
  border-radius: 999rpx;
  background: #e8f5e9;
  color: #2e7d32;
  font-size: 28rpx;
  line-height: 84rpx;
}

.secondary-button::after {
  border: 0;
}

.panel {
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.06);
}
