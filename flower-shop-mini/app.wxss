page {
  background: #f7fbf7;
  color: #333333;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.section-title {
  margin: 36rpx 0 20rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.section-subtitle {
  color: #666666;
  font-size: 26rpx;
  line-height: 1.7;
}

.primary-button {
  border-radius: 999rpx;
  background: #2e7d32;
  color: #ffffff;
  font-size: 28rpx;
}

.panel {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(46, 125, 50, 0.1);
}
