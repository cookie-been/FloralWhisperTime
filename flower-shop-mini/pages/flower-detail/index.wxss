.detail {
  margin-top: 24rpx;
  padding: 30rpx;
}

.name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.name {
  flex: 1;
  min-width: 0;
  color: #1f2937;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.45;
}

.price {
  flex-shrink: 0;
  color: #2e7d32;
  font-size: 32rpx;
  font-weight: 700;
}

.desc,
.value {
  display: block;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.8;
}

.desc {
  margin-top: 20rpx;
}

.info-block {
  margin-top: 28rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 600;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.tag {
  border-radius: 999rpx;
  background: #e8f5e9;
  padding: 8rpx 18rpx;
  color: #2e7d32;
  font-size: 24rpx;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.action-button {
  margin: 0;
  min-width: 0;
}

.action-button::after {
  border: 0;
}

.section-header {
  margin-top: 36rpx;
}

.related-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}
