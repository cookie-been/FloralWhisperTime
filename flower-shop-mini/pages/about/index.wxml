<view class="page">
  <state-section
    loading="{{isPageLoading}}"
    error-text="{{pageErrorText}}"
    has-data="{{!!story.title || !!shop.name}}"
    empty-text="关于我们内容暂不可用"
    bind:retry="handleRetry"
  >
    <view class="page-head">
      <text class="page-eyebrow">关于我们</text>
      <text class="page-title-text">{{storyTitleText}}</text>
      <text class="page-desc-text">{{storySubtitleText}}</text>
    </view>

    <image class="hero" src="{{heroImageUrl}}" mode="aspectFill" />

    <view class="panel story-card">
      <text class="eyebrow">品牌故事</text>
      <text class="content">{{storyContentText}}</text>
    </view>

    <view class="section-header">
      <text class="section-title">团队成员</text>
      <text class="section-subtitle">花艺表达背后的主理与设计团队</text>
    </view>
    <state-section
      loading="{{false}}"
      error-text=""
      has-data="{{teamMemberList.length > 0}}"
      empty-text="暂时没有团队信息"
    >
      <view class="team-list">
        <view wx:for="{{teamCardList}}" wx:key="id" class="team-card panel">
          <image class="team-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
          <view class="team-content">
            <text class="team-name">{{item.name}}</text>
            <text class="team-title">{{item.title}}</text>
            <text class="team-bio">{{item.bioText}}</text>
          </view>
        </view>
      </view>
    </state-section>

    <view class="section-header">
      <text class="section-title">门店信息</text>
      <text class="section-subtitle">线下到店、电话预约和花艺咨询入口</text>
    </view>
    <view class="panel shop-card">
      <text class="shop-name">{{shopNameText}}</text>
      <text class="shop-line">地址：{{shopAddressText}}</text>
      <text class="shop-line">电话：{{shopPhoneText}}</text>
      <text class="shop-line">微信：{{shopWechatText}}</text>
      <text class="shop-line multiline">营业时间：{{businessHoursText || '请联系门店获取最新营业安排'}}</text>
    </view>
  </state-section>
</view>
