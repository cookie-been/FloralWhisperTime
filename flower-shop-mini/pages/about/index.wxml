<view class="page">
  <state-section
    loading="{{isPageLoading}}"
    error-text="{{pageErrorText}}"
    has-data="{{!!aboutPage.heroTitle || !!story.title || !!shop.name}}"
    empty-text="关于我们内容暂不可用"
    bind:retry="handleRetry"
  >
    <view class="page-head">
      <text class="page-eyebrow">{{pageEyebrowText}}</text>
      <text class="page-title-text">{{pageTitleText}}</text>
      <text class="page-desc-text">{{pageSubtitleText}}</text>
    </view>

    <image class="hero" src="{{heroImageUrl}}" mode="aspectFill" />

    <view class="panel story-card">
      <text class="eyebrow">{{storyEyebrowText}}</text>
      <text class="story-title">{{storyTitleText}}</text>
      <text class="content">{{storyContentText}}</text>
    </view>

    <view class="section-header">
      <text class="section-eyebrow">{{timelineEyebrowText}}</text>
      <text class="section-title">{{timelineSectionTitleText}}</text>
    </view>
    <state-section
      loading="{{false}}"
      error-text=""
      has-data="{{timelineList.length > 0}}"
      empty-text="暂时没有发展历程内容"
    >
      <view class="timeline-list">
        <view wx:for="{{timelineList}}" wx:key="id" class="timeline-card panel">
          <text class="timeline-year">{{item.yearLabel}}</text>
          <text class="timeline-content">{{item.content}}</text>
        </view>
      </view>
    </state-section>

    <view class="section-header">
      <text class="section-title">{{teamSectionTitleText}}</text>
      <text class="section-subtitle">{{teamSectionIntroText}}</text>
    </view>
    <state-section
      loading="{{false}}"
      error-text=""
      has-data="{{teamMemberList.length > 0}}"
      empty-text="暂时没有团队信息"
    >
      <view class="team-list">
        <view wx:for="{{teamCardList}}" wx:key="id" class="team-card panel">
          <image class="team-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
          <view class="team-content">
            <text class="team-name">{{item.name}}</text>
            <text class="team-title">{{item.title}}</text>
            <text class="team-bio">{{item.bioText}}</text>
          </view>
        </view>
      </view>
    </state-section>

    <view class="section-header">
      <text class="section-title">门店信息</text>
      <text class="section-subtitle">线下到店、电话预约和花艺咨询入口</text>
    </view>
    <view class="panel shop-card">
      <text class="shop-name">{{shopNameText}}</text>
      <text class="shop-line">地址：{{shopAddressText}}</text>
      <text class="shop-line">电话：{{shopPhoneText}}</text>
      <text class="shop-line">微信：{{shopWechatText}}</text>
      <text class="shop-line multiline">营业时间：{{businessHoursText || '请联系门店获取最新营业安排'}}</text>
    </view>
  </state-section>
</view>
