.hero {
  width: 100%;
  height: 420rpx;
  border-radius: 24rpx;
}

.story,
.shop {
  margin-top: 24rpx;
  padding: 30rpx;
}

.eyebrow {
  display: block;
  color: #2e7d32;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  display: block;
  margin-top: 12rpx;
  color: #333333;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.35;
}

.subtitle,
.content,
.shop text {
  display: block;
  color: #666666;
  font-size: 26rpx;
  line-height: 1.8;
}

.subtitle {
  margin-top: 18rpx;
}

.content {
  margin-top: 14rpx;
}

.shop-name {
  margin-bottom: 10rpx;
  color: #333333 !important;
  font-size: 30rpx !important;
  font-weight: 700;
}
