.hero {
  width: 100%;
  height: 420rpx;
  border-radius: 24rpx;
}

.story-card,
.shop-card {
  margin-top: 24rpx;
  padding: 30rpx;
}

.eyebrow {
  display: block;
  color: #2e7d32;
  font-size: 22rpx;
  font-weight: 600;
}

.title {
  display: block;
  margin-top: 12rpx;
  color: #1f2937;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.4;
}

.subtitle,
.content,
.shop-line {
  display: block;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.8;
}

.subtitle {
  margin-top: 18rpx;
}

.content {
  margin-top: 14rpx;
}

.section-header {
  margin-top: 36rpx;
}

.team-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.team-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 22rpx;
}

.team-avatar {
  width: 132rpx;
  height: 132rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  background: #e8f5e9;
}

.team-content {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.team-name {
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 600;
}

.team-title {
  color: #2e7d32;
  font-size: 24rpx;
  line-height: 1.6;
}

.team-bio {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.7;
}

.shop-name {
  display: block;
  margin-bottom: 12rpx;
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 600;
}

.multiline {
  white-space: pre-line;
}
