.notice {
  margin-top: 24rpx;
  padding: 22rpx 26rpx;
  color: #2e7d32;
  font-size: 26rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.category {
  display: flex;
  min-height: 132rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #333333;
  font-size: 24rpx;
}

.category-icon {
  display: flex;
  width: 54rpx;
  height: 54rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #e8f5e9;
  color: #2e7d32;
  font-weight: 700;
}

.flower-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.story {
  margin-top: 32rpx;
  padding: 32rpx;
}

.story-title {
  display: block;
  color: #333333;
  font-size: 32rpx;
  font-weight: 700;
}

.story-desc {
  display: block;
  margin-top: 12rpx;
  color: #666666;
  font-size: 26rpx;
}
