.contact-head {
  margin-bottom: 28rpx;
}

.title {
  display: block;
  color: #333333;
  font-size: 44rpx;
  font-weight: 700;
}

.desc {
  display: block;
  margin-top: 12rpx;
  color: #666666;
  font-size: 26rpx;
  line-height: 1.7;
}

.actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 24rpx;
}

.actions button::after {
  border: 0;
}

.wechat-button {
  border-radius: 999rpx;
  background: #e8f5e9;
  color: #2e7d32;
  font-size: 28rpx;
}

.info {
  margin-top: 24rpx;
  padding: 30rpx;
}

.info text {
  display: block;
  color: #666666;
  font-size: 26rpx;
  line-height: 1.8;
}

.info-title {
  margin-bottom: 10rpx;
  color: #333333 !important;
  font-size: 32rpx !important;
  font-weight: 700;
}
