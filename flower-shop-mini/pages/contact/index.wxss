.contact-head {
  margin-bottom: 28rpx;
}

.title {
  display: block;
  color: #1f2937;
  font-size: 44rpx;
  font-weight: 700;
}

.desc {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.7;
}

.actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 24rpx;
}

.actions button::after {
  border: 0;
}

.action-button {
  margin: 0;
  min-width: 0;
}

.action-button[disabled] {
  opacity: 0.48;
}

.wechat-button {
  border-radius: 999rpx;
  background: #e8f5e9;
  color: #2e7d32;
  font-size: 28rpx;
}

.info {
  margin-top: 24rpx;
  padding: 30rpx;
}

.info-line {
  display: block;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.8;
}

.info-title {
  display: block;
  margin-bottom: 10rpx;
  color: #1f2937;
  font-size: 32rpx;
  font-weight: 700;
}

.section-header {
  margin-top: 36rpx;
}

.form-panel {
  margin-top: 18rpx;
  padding: 24rpx;
}

.field-input,
.field-textarea {
  width: 100%;
  border-radius: 18rpx;
  background: #f5f7f8;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  color: #1f2937;
  font-size: 26rpx;
}

.field-input + .field-input,
.field-input + .field-textarea,
.field-textarea + .submit-button {
  margin-top: 16rpx;
}

.field-textarea {
  min-height: 200rpx;
}

.form-tip {
  display: block;
  margin-top: 16rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}

.submit-button {
  margin: 18rpx 0 0;
  min-width: 0;
}

.submit-button::after {
  border: 0;
}

.multiline {
  white-space: pre-line;
}
