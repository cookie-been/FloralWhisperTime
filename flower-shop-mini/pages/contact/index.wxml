<view class="page">
  <state-section
    loading="{{isPageLoading}}"
    error-text="{{pageErrorText}}"
    has-data="{{!!shop.name}}"
    empty-text="暂时无法展示联系信息"
    bind:retry="handleRetry"
  >
    <view class="page-head">
      <text class="page-eyebrow">联系门店</text>
      <text class="page-title-text">{{shopNameText}}</text>
      <text class="page-desc-text">{{contactDescription}}</text>
    </view>

    <shop-map shop="{{shop}}" />

    <view class="panel actions">
      <button class="primary-button action-button" disabled="{{!canCallShop}}" bindtap="callShop">一键拨号</button>
      <button class="wechat-button action-button" disabled="{{!canCopyWechat}}" bindtap="copyWechat">复制微信号</button>
    </view>

    <view class="panel info">
      <text class="info-title">{{shopNameText}}</text>
      <text class="info-line">地址：{{shopAddressText}}</text>
      <text class="info-line">电话：{{shopPhoneText}}</text>
      <text class="info-line">微信：{{shopWechatText}}</text>
      <text class="info-line multiline">营业时间：{{businessHoursDisplayText}}</text>
    </view>

    <view class="section-header">
      <text class="section-title">在线留言</text>
      <text class="section-subtitle">留下需求，我们会尽快联系你</text>
    </view>
    <view class="panel form-panel">
      <input class="field-input" placeholder="你的称呼" value="{{formData.name}}" bindinput="handleNameInput" />
      <input class="field-input" placeholder="联系电话" type="text" maxlength="20" value="{{formData.phone}}" bindinput="handlePhoneInput" />
      <textarea
        class="field-textarea"
        placeholder="想预约的花束、场景或预算要求"
        maxlength="300"
        value="{{formData.message}}"
        bindinput="handleMessageInput"
      />
      <text class="form-tip">建议填写场景、预算和期望送达时间，沟通会更快。</text>
      <button class="primary-button submit-button" loading="{{isSubmitting}}" disabled="{{isSubmitting}}" bindtap="handleSubmit">
        提交留言
      </button>
    </view>
  </state-section>
</view>
