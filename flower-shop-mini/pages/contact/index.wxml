<view class="page">
  <view class="contact-head">
    <text class="title">联系我们</text>
    <text class="desc">{{siteConfig.contactIntro || '预约花束、婚礼花艺、开业花篮与空间花艺。'}}</text>
  </view>
  <shop-map shop="{{shop}}" />
  <view class="panel actions">
    <button class="primary-button" bindtap="callShop">一键拨号</button>
    <button class="wechat-button" bindtap="copyWechat">复制微信号</button>
  </view>
  <view class="panel info">
    <text class="info-title">{{shop.name}}</text>
    <text>地址：{{shop.address}}</text>
    <text>电话：{{shop.phone}}</text>
    <text>微信：{{shop.wechat}}</text>
    <text>营业时间：{{siteConfig.businessHoursText || '周一至周五 09:30-21:00，周末 10:00-21:30'}}</text>
  </view>
</view>
