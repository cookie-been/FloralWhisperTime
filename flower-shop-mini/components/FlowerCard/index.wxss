.flower-card {
  overflow: hidden;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(46, 125, 50, 0.1);
}

.cover {
  display: block;
  width: 100%;
  height: 320rpx;
  background: #e8f5e9;
}

.content {
  padding: 22rpx;
}

.name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.price {
  flex-shrink: 0;
  color: #2e7d32;
  font-size: 26rpx;
  font-weight: 700;
}

.desc {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  color: #666666;
  font-size: 24rpx;
  line-height: 1.6;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag {
  border-radius: 999rpx;
  background: #e8f5e9;
  padding: 6rpx 14rpx;
  color: #2e7d32;
  font-size: 22rpx;
}
