.flower-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.cover {
  display: block;
  width: 100%;
  height: 320rpx;
  background: #e8f5e9;
}

.content {
  padding: 22rpx 22rpx 24rpx;
}

.name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.name {
  flex: 1;
  min-width: 0;
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.5;
}

.price {
  flex-shrink: 0;
  color: #2e7d32;
  font-size: 26rpx;
  font-weight: 700;
}

.desc {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag {
  border-radius: 999rpx;
  background: #e8f5e9;
  padding: 6rpx 14rpx;
  color: #2e7d32;
  font-size: 22rpx;
}
