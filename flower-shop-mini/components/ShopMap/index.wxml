<view class="map-card">
  <map
    wx:if="{{hasLocation}}"
    class="map"
    latitude="{{shop.latitude}}"
    longitude="{{shop.longitude}}"
    markers="{{markers}}"
  />
  <view wx:else class="map-empty">暂时无法展示门店地图</view>
  <button class="nav-button" disabled="{{!hasLocation}}" bindtap="openLocation">导航到店</button>
</view>
