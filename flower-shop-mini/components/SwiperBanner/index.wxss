.banner {
  height: 420rpx;
  overflow: hidden;
  border-radius: 24rpx;
}

.banner-image {
  width: 100%;
  height: 420rpx;
}

.banner-copy {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  color: #ffffff;
}

.banner-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
}

.banner-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
}
